<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-content">
  <div class="container-fluid px-4 py-4">

    <div class="d-flex align-items-center gap-3 mb-4">
      <a href="/eventos" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
      </a>
      <h4 class="fw-bold text-dark mb-0">
        <i class="bi bi-eye-fill text-info me-2"></i>Detalle del Evento
      </h4>
    </div>

    <div class="row g-4">
      <!-- Afiche -->
      <div class="col-lg-5">
        <div class="card border-0 shadow-sm overflow-hidden">
          <% if (evento.afiche) { %>
          <img src="<%= evento.afiche %>" alt="Afiche" class="img-fluid" style="object-fit:cover; max-height:400px; width:100%;">
          <% } else { %>
          <div class="d-flex align-items-center justify-content-center bg-light" style="height:300px">
            <div class="text-center text-muted">
              <i class="bi bi-image display-3"></i>
              <p class="mt-2">Sin afiche</p>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Info -->
      <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body p-4">
            <h3 class="fw-bold text-dark mb-3"><%= evento.titulo %></h3>

            <div class="info-row mb-3">
              <div class="info-label">
                <i class="bi bi-calendar2-fill text-primary me-2"></i>Fecha
              </div>
              <div class="info-value">
                <%= new Date(evento.fecha).toLocaleDateString('es-PE', {
                  weekday: 'long', day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC'
                }) %>
              </div>
            </div>

            <div class="info-row mb-3">
              <div class="info-label">
                <i class="bi bi-person-fill text-success me-2"></i>Organizador
              </div>
              <div class="info-value fw-semibold"><%= evento.nombre_organizador || 'No asignado' %></div>
            </div>

            <% if (evento.telefono) { %>
            <div class="info-row mb-4">
              <div class="info-label">
                <i class="bi bi-telephone-fill text-warning me-2"></i>Teléfono
              </div>
              <div class="info-value"><%= evento.telefono %></div>
            </div>
            <% } %>

            <div class="d-flex gap-3 mt-4">
              <a href="/eventos/<%= evento.id_evento %>/editar" class="btn btn-warning flex-fill fw-semibold">
                <i class="bi bi-pencil-fill me-1"></i> Editar
              </a>
              <form action="/eventos/<%= evento.id_evento %>?_method=DELETE" method="POST" class="flex-fill">
                <button type="submit" class="btn btn-outline-danger w-100 btn-delete fw-semibold">
                  <i class="bi bi-trash-fill me-1"></i> Eliminar
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
