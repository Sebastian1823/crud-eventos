<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-content">
  <div class="container-fluid px-4 py-4">

    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible alert-auto-dismiss d-flex align-items-center gap-2">
      <i class="bi bi-exclamation-circle-fill"></i> <%= error %>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
      <a href="/eventos" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
      </a>
      <div>
        <h4 class="fw-bold text-dark mb-0">
          <i class="bi bi-plus-circle-fill text-primary me-2"></i>Nuevo Evento
        </h4>
        <p class="text-muted mb-0 small">Completa los datos para registrar un evento</p>
      </div>
    </div>

    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-4">
            <form action="/eventos" method="POST" enctype="multipart/form-data" novalidate>

              <div class="row g-3">
                <!-- Título -->
                <div class="col-12">
                  <label class="form-label fw-medium">
                    Título del Evento <span class="text-danger">*</span>
                  </label>
                  <input type="text" name="titulo" class="form-control"
                         placeholder="Ej: Festival de Música 2024" required maxlength="150">
                </div>

                <!-- Fecha -->
                <div class="col-md-6">
                  <label class="form-label fw-medium">
                    Fecha <span class="text-danger">*</span>
                  </label>
                  <input type="date" name="fecha" class="form-control" required>
                </div>

                <!-- Organizador -->
                <div class="col-md-6">
                  <label class="form-label fw-medium">
                    Organizador <span class="text-danger">*</span>
                  </label>
                  <select name="id_organizador" class="form-select" required>
                    <option value="">-- Seleccionar organizador --</option>
                    <% organizadores.forEach(org => { %>
                    <option value="<%= org.id_organizador %>"><%= org.nombre %></option>
                    <% }) %>
                  </select>
                  <% if (organizadores.length === 0) { %>
                  <div class="form-text text-warning">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    No hay organizadores. <a href="/organizadores/crear">Crear uno primero.</a>
                  </div>
                  <% } %>
                </div>

                <!-- Afiche -->
                <div class="col-12">
                  <label class="form-label fw-medium">Afiche del Evento</label>
                  <div class="upload-area" id="uploadArea" onclick="document.getElementById('afileInput').click()">
                    <input type="file" name="afiche" id="afileInput" accept="image/*"
                           class="d-none" onchange="previewImage(this)">
                    <div class="upload-placeholder" id="uploadPlaceholder">
                      <i class="bi bi-cloud-upload display-5 text-muted mb-2"></i>
                      <p class="mb-1 fw-medium">Haz clic para subir imagen</p>
                      <p class="text-muted small mb-0">JPG, PNG, WEBP — máx. 5MB</p>
                    </div>
                    <img id="imagePreview" src="" class="img-preview d-none" alt="Preview">
                  </div>
                </div>
              </div>

              <hr class="my-4">

              <div class="d-flex gap-3 justify-content-end">
                <a href="/eventos" class="btn btn-outline-secondary">
                  <i class="bi bi-x-circle me-1"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-primary px-4">
                  <i class="bi bi-floppy-fill me-1"></i>Guardar Evento
                </button>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
function previewImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('imagePreview').src = e.target.result;
      document.getElementById('imagePreview').classList.remove('d-none');
      document.getElementById('uploadPlaceholder').classList.add('d-none');
    };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>

<%- include('../partials/footer') %>
