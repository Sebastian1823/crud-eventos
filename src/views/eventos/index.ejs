<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-calendar-event-fill me-2" style="color: var(--nebula-blue);"></i>Eventos
    </h2>
    <a href="/eventos/create" class="btn btn-success px-4">
        <i class="bi bi-plus-circle me-1"></i> Nuevo Evento
    </a>
</div>

<% if (eventos.length === 0) { %>
    <div class="alert alert-info text-center py-4" role="alert">
        <i class="bi bi-info-circle me-2" style="font-size:1.2rem;"></i>No hay eventos registrados.
    </div>
<% } else { %>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Título</th>
                        <th>Fecha</th>
                        <th>Afiche</th>
                        <th>Organizador</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% eventos.forEach((evento, index) => { %>
                        <tr>
                            <td><span class="badge-img"><%= index + 1 %></span></td>
                            <td><strong><%= evento.titulo %></strong></td>
                            <td>
                                <i class="bi bi-calendar3 me-1" style="color: var(--nebula-cyan); opacity:0.7;"></i>
                                <%= new Date(evento.fecha).toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                            </td>
                            <td>
                                <% if (evento.afiche) { %>
                                    <img src="<%= evento.afiche %>" alt="Afiche" width="80" class="img-thumbnail-custom">
                                <% } else { %>
                                    <span class="badge bg-secondary"><i class="bi bi-image me-1"></i>Sin imagen</span>
                                <% } %>
                            </td>
                            <td>
                                <i class="bi bi-person-circle me-1" style="color: var(--nebula-purple); opacity:0.7;"></i>
                                <%= evento.nombre_organizador %>
                            </td>
                            <td class="text-center">
                                <a href="/eventos/<%= evento.id_evento %>/edit" class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <form action="/eventos/<%= evento.id_evento %>?_method=DELETE" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Está seguro de eliminar este evento?')">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
<% } %>

<%- include('../partials/footer') %>
