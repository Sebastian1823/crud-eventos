<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-content">
  <div class="container-fluid px-4 py-4">

    <!-- Alertas -->
    <% if (success) { %>
    <div class="alert alert-success alert-dismissible alert-auto-dismiss d-flex align-items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> <%= success %>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible alert-auto-dismiss d-flex align-items-center gap-2">
      <i class="bi bi-exclamation-circle-fill"></i> <%= error %>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h4 class="fw-bold text-dark mb-1">
          <i class="bi bi-calendar3 text-primary me-2"></i>Eventos
        </h4>
        <p class="text-muted mb-0"><%= eventos.length %> evento(s) registrado(s)</p>
      </div>
      <a href="/eventos/crear" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="bi bi-plus-circle-fill"></i> Nuevo Evento
      </a>
    </div>

    <!-- Cards de eventos -->
    <% if (eventos.length === 0) { %>
    <div class="empty-state text-center py-5">
      <i class="bi bi-calendar-x display-1 text-muted"></i>
      <h5 class="mt-3 text-muted">No hay eventos registrados</h5>
      <p class="text-muted">Comienza creando tu primer evento.</p>
      <a href="/eventos/crear" class="btn btn-primary mt-2">
        <i class="bi bi-plus me-1"></i> Crear primer evento
      </a>
    </div>
    <% } else { %>
    <div class="row g-4">
      <% eventos.forEach(evento => { %>
      <div class="col-md-6 col-xl-4">
        <div class="event-card card border-0 shadow-sm h-100">
          <!-- Afiche -->
          <div class="event-card-img">
            <% if (evento.afiche) { %>
              <img src="<%= evento.afiche %>" alt="Afiche de <%= evento.titulo %>" class="card-img-top">
            <% } else { %>
              <div class="no-image d-flex align-items-center justify-content-center">
                <i class="bi bi-image text-muted"></i>
              </div>
            <% } %>
            <!-- Badge fecha -->
            <div class="event-date-badge">
              <i class="bi bi-calendar2-fill me-1"></i>
              <%= new Date(evento.fecha).toLocaleDateString('es-PE', { day:'2-digit', month:'short', year:'numeric', timeZone:'UTC' }) %>
            </div>
          </div>

          <div class="card-body">
            <h5 class="card-title fw-semibold text-dark mb-2"><%= evento.titulo %></h5>
            <div class="d-flex align-items-center gap-2 mb-3">
              <div class="organizer-avatar">
                <i class="bi bi-person-fill"></i>
              </div>
              <div>
                <p class="mb-0 small fw-medium text-dark"><%= evento.nombre_organizador || 'Sin organizador' %></p>
                <% if (evento.telefono) { %>
                <p class="mb-0 text-muted" style="font-size:0.75rem">
                  <i class="bi bi-telephone-fill me-1"></i><%= evento.telefono %>
                </p>
                <% } %>
              </div>
            </div>
          </div>

          <div class="card-footer bg-white border-top-0 pt-0 pb-3 px-3">
            <div class="d-flex gap-2">
              <a href="/eventos/<%= evento.id_evento %>" class="btn btn-sm btn-outline-info flex-fill">
                <i class="bi bi-eye-fill me-1"></i>Ver
              </a>
              <a href="/eventos/<%= evento.id_evento %>/editar" class="btn btn-sm btn-outline-warning flex-fill">
                <i class="bi bi-pencil-fill me-1"></i>Editar
              </a>
              <form action="/eventos/<%= evento.id_evento %>?_method=DELETE" method="POST" class="flex-fill">
                <button type="submit" class="btn btn-sm btn-outline-danger w-100 btn-delete">
                  <i class="bi bi-trash-fill me-1"></i>Eliminar
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

  </div>
</div>

<%- include('../partials/footer') %>
