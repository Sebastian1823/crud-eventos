<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-content">
  <div class="container-fluid px-4 py-4">

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible alert-auto-dismiss d-flex align-items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> <%= success %>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible alert-auto-dismiss d-flex align-items-center gap-2">
      <i class="bi bi-exclamation-circle-fill"></i> <%= error %>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h4 class="fw-bold text-dark mb-1">
          <i class="bi bi-people-fill text-success me-2"></i>Organizadores
        </h4>
        <p class="text-muted mb-0"><%= organizadores.length %> organizador(es) registrado(s)</p>
      </div>
      <a href="/organizadores/crear" class="btn btn-success d-flex align-items-center gap-2">
        <i class="bi bi-person-plus-fill"></i> Nuevo Organizador
      </a>
    </div>

    <!-- Tabla -->
    <% if (organizadores.length === 0) { %>
    <div class="empty-state text-center py-5">
      <i class="bi bi-people display-1 text-muted"></i>
      <h5 class="mt-3 text-muted">No hay organizadores registrados</h5>
      <a href="/organizadores/crear" class="btn btn-success mt-2">
        <i class="bi bi-plus me-1"></i>Crear primer organizador
      </a>
    </div>
    <% } else { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="px-4 py-3">#</th>
                <th class="py-3">Nombre</th>
                <th class="py-3">Teléfono</th>
                <th class="py-3 text-center">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% organizadores.forEach((org, i) => { %>
              <tr>
                <td class="px-4 text-muted small"><%= i + 1 %></td>
                <td>
                  <div class="d-flex align-items-center gap-3">
                    <div class="org-avatar">
                      <%= org.nombre.charAt(0).toUpperCase() %>
                    </div>
                    <span class="fw-medium"><%= org.nombre %></span>
                  </div>
                </td>
                <td>
                  <span class="d-flex align-items-center gap-1 text-muted">
                    <i class="bi bi-telephone-fill text-success"></i>
                    <%= org.telefono %>
                  </span>
                </td>
                <td class="text-center">
                  <div class="d-flex gap-2 justify-content-center">
                    <a href="/organizadores/<%= org.id_organizador %>/editar"
                       class="btn btn-sm btn-outline-warning d-flex align-items-center gap-1">
                      <i class="bi bi-pencil-fill"></i> Editar
                    </a>
                    <form action="/organizadores/<%= org.id_organizador %>?_method=DELETE" method="POST">
                      <button type="submit" class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1 btn-delete">
                        <i class="bi bi-trash-fill"></i> Eliminar
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

  </div>
</div>

<%- include('../partials/footer') %>
