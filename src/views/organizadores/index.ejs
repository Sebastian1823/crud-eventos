<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-people-fill me-2" style="color: var(--nebula-blue);"></i>Organizadores
    </h2>
    <a href="/organizadores/create" class="btn btn-success px-4">
        <i class="bi bi-plus-circle me-1"></i> Nuevo Organizador
    </a>
</div>

<% if (organizadores.length === 0) { %>
    <div class="alert alert-info text-center py-4" role="alert">
        <i class="bi bi-info-circle me-2" style="font-size:1.2rem;"></i>No hay organizadores registrados.
    </div>
<% } else { %>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Telefono</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% organizadores.forEach((org, index) => { %>
                        <tr>
                            <td><span class="badge-img"><%= index + 1 %></span></td>
                            <td>
                                <i class="bi bi-person-circle me-2" style="color: var(--nebula-purple); opacity:0.7;"></i>
                                <strong><%= org.nombre %></strong>
                            </td>
                            <td>
                                <i class="bi bi-telephone-fill me-1" style="color: var(--nebula-cyan); opacity:0.6;"></i>
                                <%= org.telefono %>
                            </td>
                            <td class="text-center">
                                <a href="/organizadores/<%= org.id_organizador %>/edit" class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <form action="/organizadores/<%= org.id_organizador %>?_method=DELETE" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Está seguro de eliminar este organizador?')">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
<% } %>

<%- include('../partials/footer') %>
