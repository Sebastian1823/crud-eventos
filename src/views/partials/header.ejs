<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎭 GestorEventos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* ═══════ COSMIC THEME — CORE ═══════ */
        :root {
            --space-darkest: #050816;
            --space-dark: #0a0e1a;
            --space-mid: #111631;
            --space-card: #0d1025;
            --space-card-border: rgba(99, 135, 255, 0.08);
            --nebula-blue: #4f6df5;
            --nebula-purple: #7c3aed;
            --nebula-cyan: #22d3ee;
            --nebula-pink: #c084fc;
            --star-white: #e2e8f0;
            --star-dim: #8892b0;
            --glow-blue: rgba(79, 109, 245, 0.35);
            --glow-purple: rgba(124, 58, 237, 0.3);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--space-darkest);
            color: var(--star-white);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* ═══════ ANIMATED STARFIELD BACKGROUND ═══════ */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(79, 109, 245, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(124, 58, 237, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 80%, rgba(34, 211, 238, 0.04) 0%, transparent 50%);
            z-index: 0;
            pointer-events: none;
        }

        #stars-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* ═══════ NAVBAR ═══════ */
        .navbar {
            position: relative;
            z-index: 100;
            background: rgba(10, 14, 26, 0.75) !important;
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid rgba(79, 109, 245, 0.1);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4), 0 1px 0 rgba(79, 109, 245, 0.05);
            padding: 0.8rem 0;
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #4f6df5, #22d3ee, #c084fc);
            background-size: 200% 200%;
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shimmer 4s ease-in-out infinite;
            text-shadow: 0 0 30px rgba(79, 109, 245, 0.3);
        }

        @keyframes shimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .nav-link {
            color: var(--star-dim) !important;
            font-weight: 500;
            font-size: 0.92rem;
            padding: 0.5rem 1.1rem !important;
            border-radius: 8px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }
        .nav-link:hover {
            color: #fff !important;
            background: rgba(79, 109, 245, 0.1);
            transform: translateY(-1px);
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 2px;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #4f6df5, #22d3ee);
            border-radius: 2px;
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }
        .nav-link:hover::after {
            width: 60%;
        }

        /* ═══════ MAIN CONTENT ═══════ */
        .main-content {
            flex: 1;
            padding-top: 2.5rem;
            padding-bottom: 2.5rem;
            position: relative;
            z-index: 10;
        }

        /* ═══════ PAGE TITLE ═══════ */
        h2 {
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        /* ═══════ CARDS — GLASSMORPHISM ═══════ */
        .card {
            background: rgba(13, 16, 37, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--space-card-border);
            border-radius: 16px;
            box-shadow:
                0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.03);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            overflow: hidden;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow:
                0 12px 40px rgba(79, 109, 245, 0.12),
                0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        .card-header {
            background: linear-gradient(135deg, rgba(79, 109, 245, 0.08), rgba(124, 58, 237, 0.05));
            border-bottom: 1px solid rgba(79, 109, 245, 0.08);
            border-radius: 16px 16px 0 0 !important;
            padding: 1.2rem 1.5rem;
        }
        .card-body {
            padding: 1.5rem;
        }

        /* ═══════ TABLE ═══════ */
        .table {
            color: var(--star-white);
            margin-bottom: 0;
        }
        .table thead th {
            background: rgba(79, 109, 245, 0.06);
            color: var(--nebula-cyan);
            text-transform: uppercase;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            border-bottom: 1px solid rgba(79, 109, 245, 0.1);
            padding: 1rem 0.85rem;
        }
        .table tbody tr {
            transition: all 0.25s ease;
            border-bottom: 1px solid rgba(255, 255, 255, 0.025);
        }
        .table tbody tr:hover {
            background: rgba(79, 109, 245, 0.06);
        }
        .table td, .table th {
            vertical-align: middle;
            border-color: rgba(255, 255, 255, 0.025);
            padding: 0.85rem;
        }

        /* ═══════ BUTTONS ═══════ */
        .btn {
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.88rem;
            letter-spacing: 0.2px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        .btn::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            transition: left 0.5s ease;
        }
        .btn:hover::before {
            left: 100%;
        }
        .btn:hover {
            transform: translateY(-2px);
        }
        .btn:active {
            transform: translateY(0);
        }

        .btn-success {
            background: linear-gradient(135deg, #10b981, #06d6a0);
            border: none;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.25);
        }
        .btn-success:hover {
            background: linear-gradient(135deg, #059669, #10b981);
            box-shadow: 0 6px 25px rgba(16, 185, 129, 0.35);
        }

        .btn-warning {
            background: linear-gradient(135deg, #f59e0b, #fbbf24);
            border: none;
            color: #0a0e1a;
            font-weight: 700;
            box-shadow: 0 4px 15px rgba(245, 158, 11, 0.2);
        }
        .btn-warning:hover {
            background: linear-gradient(135deg, #d97706, #f59e0b);
            color: #0a0e1a;
            box-shadow: 0 6px 25px rgba(245, 158, 11, 0.3);
        }

        .btn-danger {
            background: linear-gradient(135deg, #ef4444, #f87171);
            border: none;
            box-shadow: 0 4px 15px rgba(239, 68, 68, 0.2);
        }
        .btn-danger:hover {
            background: linear-gradient(135deg, #dc2626, #ef4444);
            box-shadow: 0 6px 25px rgba(239, 68, 68, 0.35);
        }

        .btn-primary {
            background: linear-gradient(135deg, #4f6df5, #7c3aed);
            border: none;
            box-shadow: 0 4px 15px var(--glow-blue);
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #4361e6, #6d28d9);
            box-shadow: 0 6px 25px var(--glow-blue), 0 0 40px rgba(79, 109, 245, 0.15);
        }

        .btn-outline-secondary {
            border: 1px solid rgba(255, 255, 255, 0.12);
            color: var(--star-dim);
            background: transparent;
        }
        .btn-outline-secondary:hover {
            border-color: rgba(79, 109, 245, 0.4);
            color: var(--star-white);
            background: rgba(79, 109, 245, 0.06);
        }

        /* ═══════ FORMS ═══════ */
        .form-control, .form-select {
            background: rgba(17, 22, 49, 0.8);
            border: 1px solid rgba(79, 109, 245, 0.12);
            color: var(--star-white);
            border-radius: 10px;
            padding: 0.65rem 1rem;
            font-size: 0.92rem;
            transition: all 0.3s ease;
        }
        .form-control:focus, .form-select:focus {
            background: rgba(17, 22, 49, 0.95);
            border-color: var(--nebula-blue);
            color: var(--star-white);
            box-shadow: 0 0 0 3px rgba(79, 109, 245, 0.15), 0 0 20px rgba(79, 109, 245, 0.08);
        }
        .form-control::placeholder {
            color: rgba(136, 146, 176, 0.5);
        }
        .form-label {
            color: var(--star-dim);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.4rem;
        }
        .form-text {
            color: rgba(136, 146, 176, 0.6) !important;
        }

        /* ═══════ BADGES ═══════ */
        .badge-img {
            background: linear-gradient(135deg, rgba(79, 109, 245, 0.15), rgba(124, 58, 237, 0.1));
            color: var(--nebula-cyan);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.78rem;
            font-weight: 700;
            border: 1px solid rgba(79, 109, 245, 0.1);
        }

        .badge.bg-secondary {
            background: rgba(136, 146, 176, 0.12) !important;
            color: var(--star-dim);
            font-weight: 500;
            border: 1px solid rgba(136, 146, 176, 0.1);
        }

        /* ═══════ ALERTS ═══════ */
        .alert-info {
            background: rgba(34, 211, 238, 0.06);
            border: 1px solid rgba(34, 211, 238, 0.12);
            color: var(--nebula-cyan);
            border-radius: 12px;
            backdrop-filter: blur(10px);
        }

        /* ═══════ IMAGES ═══════ */
        .img-thumbnail-custom {
            border-radius: 10px;
            border: 2px solid rgba(79, 109, 245, 0.15);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
            transition: all 0.3s ease;
        }
        .img-thumbnail-custom:hover {
            border-color: rgba(79, 109, 245, 0.35);
            box-shadow: 0 6px 25px rgba(79, 109, 245, 0.15);
            transform: scale(1.05);
        }

        /* ═══════ ANIMATIONS ═══════ */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 5px rgba(79, 109, 245, 0.2); }
            50% { box-shadow: 0 0 20px rgba(79, 109, 245, 0.4), 0 0 40px rgba(79, 109, 245, 0.1); }
        }

        .main-content .container {
            animation: fadeInUp 0.5s ease-out;
        }

        /* ═══════ SCROLLBAR ═══════ */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--space-darkest);
        }
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--nebula-blue), var(--nebula-purple));
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, #6380f7, #9055f5);
        }

        /* ═══════ TABLE ROW ANIMATION ═══════ */
        .table tbody tr {
            animation: fadeInUp 0.4s ease-out both;
        }
        .table tbody tr:nth-child(1) { animation-delay: 0.05s; }
        .table tbody tr:nth-child(2) { animation-delay: 0.1s; }
        .table tbody tr:nth-child(3) { animation-delay: 0.15s; }
        .table tbody tr:nth-child(4) { animation-delay: 0.2s; }
        .table tbody tr:nth-child(5) { animation-delay: 0.25s; }
        .table tbody tr:nth-child(6) { animation-delay: 0.3s; }
        .table tbody tr:nth-child(7) { animation-delay: 0.35s; }
        .table tbody tr:nth-child(8) { animation-delay: 0.4s; }

        /* ═══════ RESPONSIVE ═══════ */
        @media (max-width: 768px) {
            .btn-sm { font-size: 0.78rem; padding: 0.3rem 0.6rem; }
            .table { font-size: 0.85rem; }
        }
    </style>
</head>
<body>
    <canvas id="stars-canvas"></canvas>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/eventos">🎭 GestorEventos</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" href="/eventos">
                            <i class="bi bi-calendar-event me-1"></i>Eventos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/organizadores">
                            <i class="bi bi-people me-1"></i>Organizadores
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="main-content">
        <div class="container">
