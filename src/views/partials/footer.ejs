        </div>
    </div>
    <footer class="text-center py-4 mt-auto" style="position:relative; z-index:10; background: rgba(10,14,26,0.8); backdrop-filter:blur(16px); border-top: 1px solid rgba(79,109,245,0.08);">
        <p class="mb-0" style="font-size: 0.85rem; color: var(--star-dim);">
            <span style="background: linear-gradient(135deg, #4f6df5, #22d3ee); background-clip:text; -webkit-background-clip:text; -webkit-text-fill-color:transparent; font-weight:700;">✦ GestorEventos</span>
            &nbsp;&copy; 2025 — Panel de Administración
        </p>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ═══════ ANIMATED STARFIELD ═══════
        (function() {
            const canvas = document.getElementById('stars-canvas');
            const ctx = canvas.getContext('2d');
            let stars = [];
            let shootingStars = [];

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);

            // Create stars
            for (let i = 0; i < 200; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    radius: Math.random() * 1.5 + 0.3,
                    alpha: Math.random() * 0.8 + 0.2,
                    speed: Math.random() * 0.005 + 0.002,
                    phase: Math.random() * Math.PI * 2,
                    color: Math.random() > 0.7
                        ? `rgba(79, 109, 245, `
                        : Math.random() > 0.5
                            ? `rgba(34, 211, 238, `
                            : `rgba(226, 232, 240, `
                });
            }

            function spawnShootingStar() {
                if (Math.random() < 0.003 && shootingStars.length < 2) {
                    shootingStars.push({
                        x: Math.random() * canvas.width,
                        y: 0,
                        len: Math.random() * 80 + 40,
                        speed: Math.random() * 6 + 4,
                        alpha: 1,
                        angle: Math.PI / 4 + (Math.random() - 0.5) * 0.3
                    });
                }
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                const time = Date.now() * 0.001;

                // Draw stars
                stars.forEach(s => {
                    const twinkle = Math.sin(time * s.speed * 200 + s.phase) * 0.3 + 0.7;
                    const a = s.alpha * twinkle;
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
                    ctx.fillStyle = s.color + a + ')';
                    ctx.fill();
                });

                // Shooting stars
                spawnShootingStar();
                shootingStars = shootingStars.filter(ss => {
                    ss.x += Math.cos(ss.angle) * ss.speed;
                    ss.y += Math.sin(ss.angle) * ss.speed;
                    ss.alpha -= 0.008;

                    const grad = ctx.createLinearGradient(
                        ss.x, ss.y,
                        ss.x - Math.cos(ss.angle) * ss.len,
                        ss.y - Math.sin(ss.angle) * ss.len
                    );
                    grad.addColorStop(0, `rgba(79, 109, 245, ${ss.alpha})`);
                    grad.addColorStop(1, 'rgba(79, 109, 245, 0)');

                    ctx.beginPath();
                    ctx.moveTo(ss.x, ss.y);
                    ctx.lineTo(
                        ss.x - Math.cos(ss.angle) * ss.len,
                        ss.y - Math.sin(ss.angle) * ss.len
                    );
                    ctx.strokeStyle = grad;
                    ctx.lineWidth = 1.5;
                    ctx.stroke();

                    return ss.alpha > 0 && ss.y < canvas.height + 50;
                });

                requestAnimationFrame(animate);
            }
            animate();
        })();
    </script>
</body>
</html>
